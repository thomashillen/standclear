# StandClear — environment variables
# Copy to .env.local for local development. Never commit real values.

# ─── Required ───────────────────────────────────────────────────────
# Two Mapbox tokens with different scopes (can be the same token in dev,
# should be separate restricted tokens in production):
#
# MAPBOX_TOKEN — server-only. Used by /api/geocode (suggest + retrieve)
#   and /api/walk (directions). Never sent to the browser. No URL
#   restriction needed since it only runs on the server.
MAPBOX_TOKEN=
#
# NEXT_PUBLIC_MAPBOX_TOKEN — client-visible. Used by Mapbox GL JS to
#   authenticate tile requests. Ships in the client bundle. Before
#   production, restrict it at https://account.mapbox.com/access-tokens/
#   under "URL restrictions" to your production domain(s) so a leaked
#   token can't be billed from arbitrary origins. Rotate quarterly.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Optional ───────────────────────────────────────────────────────
# Canonical site URL — used by <head>'s OpenGraph + Twitter card,
# robots.txt, and sitemap.xml. Defaults to https://standclear.app.
# NEXT_PUBLIC_SITE_URL=https://standclear.app

# Sentry DSN for client + server error tracking. Leave unset in dev;
# when set, lib/observability.ts initializes Sentry on first import.
# NEXT_PUBLIC_SENTRY_DSN=

# Vercel Analytics is auto-wired in app/layout.tsx — no env var needed.
# Set this to "0" to disable analytics in non-production previews.
# NEXT_PUBLIC_ANALYTICS_ENABLED=1
