.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code agent config (launch configs, local settings)
/.claude/

# ─── iOS / Capacitor build artifacts ──────────────────────────────
# The iOS Xcode project itself is committed (everyone needs it to
# build), but generated build outputs, user-specific Xcode state,
# and CocoaPods downloads stay local.
#
# Note: `ios/App/App/public/` IS tracked, despite being regenerated
# by `cap sync`. The Xcode project's pbxproj references it as a
# required bundle resource, and a fresh checkout would otherwise
# fail to build until the developer ran `npx cap sync ios` manually.
# Committing the synced output makes the documented Mac flow
# (`pod install && cap:open:ios`) work without an extra step. When
# native-shell/ or capacitor.config.ts changes, `cap sync` will
# update this folder; commit the diff alongside.
/ios/App/Pods/
/ios/App/Podfile.lock
/ios/App/build/
/ios/App/DerivedData/
/ios/App/App.xcworkspace/xcuserdata/
/ios/App/App.xcodeproj/xcuserdata/
/ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
/ios/App/App.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
/ios/.last_build_id
*.xcuserstate

# ─── Android / Capacitor build artifacts ──────────────────────────
# Pre-emptive — these only matter once `npx cap add android` runs
# but adding them now keeps a future Android-add diff clean.
/android/app/build/
/android/build/
/android/.gradle/
/android/local.properties
/android/captures/
/android/app/release/
